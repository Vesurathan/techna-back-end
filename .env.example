APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Must match where Laravel is reachable (include port for `php artisan serve`, e.g. :8000).
# Wrong APP_URL breaks image URLs: browser will use port 80 for http://localhost and get ERR_CONNECTION_REFUSED.
APP_URL=http://127.0.0.1:8000

# Optional: override default super admin created by db:seed (defaults: admin@techna.edu / password)
# SEED_SUPER_ADMIN_EMAIL=
# SEED_SUPER_ADMIN_PASSWORD=

# CORS: comma-separated browser origins allowed to call the API (omit to use defaults in config/cors.php)
# CORS_ALLOWED_ORIGINS=https://technatechnicalinstitute.com,https://admin.technatechnicalinstitute.com
# CORS_SUPPORTS_CREDENTIALS=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Uploads (gallery, photo library, question images) ---
# Local dev: public  |  Production with DigitalOcean Spaces: spaces
# If this stays "public", files only go to storage/app/public on the server — NOT your Space.
FILESYSTEM_UPLOADS_DISK=public

# DigitalOcean: API → Spaces → Spaces Access Keys. Region must match the Space (e.g. nyc3, sgp1).
# DO_SPACES_ENDPOINT is required — without it the AWS SDK talks to Amazon S3, not DigitalOcean.
# DO_SPACES_URL = public base for browser links (Origin Endpoint or CDN), e.g.:
#   https://your-space-name.nyc3.digitaloceanspaces.com
# After editing .env on the server: php artisan config:clear  (and config:cache if you use it)
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_REGION=nyc3
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_URL=
DO_SPACES_USE_PATH_STYLE_ENDPOINT=false
# Set to false only if you need to swallow Spaces errors (not recommended)
# FILESYSTEM_SPACES_THROW=true
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
